<!doctype html>
<html lang="id">
<head>
  <%- include('../partials/_head', { title: title }) %>
</head>
<body>

<%- include('../partials/_sidebar', { user: user }) %>

<main id="content">
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
    <div class="flex h-14 w-full items-center gap-2 px-4">
      <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
        aria-label="Toggle sidebar" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
      </button>
      <nav aria-label="breadcrumb" class="flex items-center gap-1.5 text-sm">
        <a href="/home" class="text-muted-foreground hover:text-foreground transition-colors">Beranda</a>
        <span class="text-muted-foreground">/</span>
        <a href="/ruangan" class="text-muted-foreground hover:text-foreground transition-colors">Ruangan</a>
        <span class="text-muted-foreground">/</span>
        <span class="text-foreground font-medium">Edit Ruangan</span>
      </nav>
      <div class="ml-auto flex items-center gap-2">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
          aria-label="Toggle dark mode" class="btn-icon-outline size-8">
          <span class="hidden dark:block"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></span>
          <span class="block dark:hidden"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
        </button>
        <a href="/logout" class="btn-outline btn-sm gap-1.5 hidden sm:flex">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </div>
    </div>
  </header>

  <div class="p-4 sm:p-6 max-w-2xl mx-auto space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Edit Ruangan</h1>
      <p class="text-muted-foreground text-sm mt-1">Perbarui informasi ruangan <strong><%= ruangan.room_name %></strong>.</p>
    </div>

    <% if (errors && errors.length > 0) { %>
    <div class="alert alert-destructive">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div>
        <p class="font-medium">Terdapat kesalahan:</p>
        <ul class="text-sm list-disc list-inside mt-1">
          <% errors.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
      </div>
    </div>
    <% } %>

    <div class="card">
      <div class="card-content pt-6">
        <form id="form-edit-ruangan" action="/ruangan/<%= ruangan.id %>/update" method="POST" enctype="multipart/form-data" class="space-y-5">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="field">
              <label class="label" for="room_name">Nama Ruangan <span class="text-destructive">*</span></label>
              <input type="text" id="room_name" name="room_name"
                value="<%= ruangan.room_name || '' %>"
                class="input w-full" required />
            </div>
            <div class="field">
              <label class="label" for="room_code">Kode Ruangan <span class="text-destructive">*</span></label>
              <input type="text" id="room_code" name="room_code"
                value="<%= ruangan.room_code || '' %>"
                class="input w-full" required />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="field sm:col-span-1">
              <label class="label" for="building_id">Gedung <span class="text-destructive">*</span></label>
              <select id="building_id" name="building_id" class="select w-full" required>
                <option value="">Pilih Gedung</option>
                <% buildings.forEach(b => { %>
                <option value="<%= b.id %>" <%= ruangan.building_id == b.id ? 'selected' : '' %>><%= b.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label class="label" for="floor">Lantai</label>
              <input type="text" id="floor" name="floor"
                value="<%= ruangan.floor || '' %>"
                class="input w-full" />
            </div>
            <div class="field">
              <label class="label" for="capacity">Kapasitas</label>
              <input type="number" id="capacity" name="capacity" min="0"
                value="<%= ruangan.capacity || 0 %>"
                class="input w-full" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="field">
              <label class="label" for="photo">Foto Ruangan</label>
              <% if (ruangan.photo) { %>
              <div class="mb-2">
                <img src="/uploads/ruangan/<%= ruangan.photo %>" alt="foto saat ini" class="h-20 rounded-md border">
                <p class="text-xs text-muted-foreground mt-1">Foto saat ini. Upload baru untuk menggantinya.</p>
              </div>
              <% } %>
              <input type="file" id="photo" name="photo" accept="image/jpeg,image/png,image/webp"
                class="input w-full" />
              <p class="field-description">JPG, PNG, WebP. Maks. 2MB.</p>
            </div>
            <div class="field flex flex-col justify-center">
              <label class="label">Akses Publik</label>
              <div class="flex items-center gap-3 mt-2">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="is_public" value="1" class="radio" <%= ruangan.is_public ? 'checked' : '' %>> Ya
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="is_public" value="0" class="radio" <%= !ruangan.is_public ? 'checked' : '' %>> Tidak
                </label>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-end gap-3 pt-2">
            <a href="/ruangan" class="btn-outline">Batal</a>
            <button type="submit" id="btn-update-ruangan" class="btn gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Simpan Perubahan
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</main>

</body>
</html>
