<!doctype html>
<html lang="id">
<head>
  <%- include('partials/_head', { title: 'Dashboard — FTI Aset' }) %>
</head>
<body>

<%- include('partials/_sidebar', { user: user }) %>

<main id="content">

  <%# === TOP HEADER BAR === %>
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
    <div class="flex h-14 w-full items-center gap-2 px-4">

      <button
        type="button"
        onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
        aria-label="Toggle sidebar"
        class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="18" x="3" y="3" rx="2"/>
          <path d="M9 3v18"/>
        </svg>
      </button>

      <nav aria-label="breadcrumb" class="flex items-center gap-1.5 text-sm">
        <span class="text-foreground font-medium">Dashboard</span>
      </nav>

      <%# Dark mode toggle + Logout di kanan %>
      <div class="ml-auto flex items-center gap-2">

        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
          aria-label="Toggle dark mode"
          class="btn-icon-outline size-8"
        >
          <span class="hidden dark:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
          </span>
          <span class="block dark:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </span>
        </button>

        <a
          href="/logout"
          id="btn-logout"
          class="btn-secondary btn-sm gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Logout
        </a>

      </div>
    </div>
  </header>

  <%# === MAIN DASHBOARD CONTENT === %>
  <div class="p-6 max-w-5xl mx-auto space-y-8">

    <%# WELCOME SECTION %>
    <div class="flex flex-col gap-1">
      <h1 class="text-2xl font-bold tracking-tight">
        Selamat datang, <%= user || 'Admin' %>
      </h1>
      <p class="text-muted-foreground">
        Sistem Informasi Manajemen Gedung dan Ruangan — Fakultas Teknologi Informasi
      </p>
    </div>

    <%# MODULE CARDS %>
    <section>
      <h2 class="text-sm font-medium text-muted-foreground uppercase tracking-widest mb-4">Menu Utama</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Card: Kelola Gedung %>
        <a href="/gedung" id="card-kelola-gedung" class="card group hover:border-primary transition-all duration-200 cursor-pointer no-underline block">
          <header>
            <div class="flex items-start justify-between mb-3">
              <div class="bg-primary/10 text-primary rounded-xl p-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="2" width="16" height="20" rx="2"/>
                  <path d="M9 22V12h6v10"/>
                  <path d="M8 7h.01"/><path d="M16 7h.01"/>
                  <path d="M12 7h.01"/><path d="M12 11h.01"/>
                  <path d="M16 11h.01"/><path d="M8 11h.01"/>
                </svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200 mt-1">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
            <h2 class="text-base font-semibold group-hover:text-primary transition-colors">Data Gedung</h2>
            <p class="text-sm text-muted-foreground mt-1">
              Kelola informasi seluruh gedung di lingkungan fakultas.
            </p>
          </header>
        </a>

        <%# Card: Aset Ruangan %>
        <a href="/aset" id="card-aset-ruangan" class="card group hover:border-primary transition-all duration-200 cursor-pointer no-underline block">
          <header>
            <div class="flex items-start justify-between mb-3">
              <div class="bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-xl p-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 7V5a2 2 0 0 1 2-2h2"/>
                  <path d="M17 3h2a2 2 0 0 1 2 2v2"/>
                  <path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
                  <path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
                  <rect x="7" y="7" width="10" height="10" rx="1"/>
                </svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200 mt-1">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
            <h2 class="text-base font-semibold group-hover:text-primary transition-colors">Data Ruangan & Aset</h2>
            <p class="text-sm text-muted-foreground mt-1">
              Pencatatan ruangan beserta status dan rincian aset di dalamnya.
            </p>
          </header>
        </a>

      </div>
    </section>

  </div><%# end max-w-5xl %>
</main>

</body>
</html>
