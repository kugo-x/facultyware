<!doctype html>
<html lang="id">
<head>
  <%- include('partials/_head', { title: 'Dashboard — FTI Aset' }) %>
</head>
<body>

<%- include('partials/_sidebar', { user: user }) %>

<main id="content">

  <%# === TOP HEADER BAR === %>
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
    <div class="flex h-14 w-full items-center gap-2 px-4">

      <button
        type="button"
        onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
        aria-label="Toggle sidebar"
        class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="18" x="3" y="3" rx="2"/>
          <path d="M9 3v18"/>
        </svg>
      </button>

      <nav aria-label="breadcrumb" class="flex items-center gap-1.5 text-sm">
        <span class="text-foreground font-medium">Dashboard</span>
      </nav>

      <%# Dark mode toggle + Logout di kanan %>
      <div class="ml-auto flex items-center gap-2">

        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
          aria-label="Toggle dark mode"
          class="btn-icon-outline size-8"
        >
          <span class="hidden dark:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
          </span>
          <span class="block dark:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </span>
        </button>

        <a
          href="/logout"
          id="btn-logout"
          class="btn-outline btn-sm gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Logout
        </a>

      </div>
    </div>
  </header>

  <%# === MAIN DASHBOARD CONTENT === %>
  <div class="p-6 max-w-5xl mx-auto space-y-8">

    <%# WELCOME SECTION %>
    <div class="flex flex-col gap-1">
      <h1 class="text-2xl font-bold tracking-tight">
        Selamat datang, <%= user || 'Admin' %>! 👋
      </h1>
      <p class="text-muted-foreground">
        Sistem Manajemen Aset Ruangan — Fakultas Teknologi Informasi.
      </p>
    </div>

    <%# MODULE CARDS %>
    <section>
      <h2 class="text-sm font-medium text-muted-foreground uppercase tracking-widest mb-4">Modul Tersedia</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Card: Kelola Gedung %>
        <a href="/gedung" id="card-kelola-gedung" class="card group hover:border-primary transition-all duration-200 cursor-pointer no-underline block">
          <header>
            <div class="flex items-start justify-between mb-3">
              <div class="bg-primary/10 text-primary rounded-xl p-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="2" width="16" height="20" rx="2"/>
                  <path d="M9 22V12h6v10"/>
                  <path d="M8 7h.01"/><path d="M16 7h.01"/>
                  <path d="M12 7h.01"/><path d="M12 11h.01"/>
                  <path d="M16 11h.01"/><path d="M8 11h.01"/>
                </svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200 mt-1">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
            <h2 class="text-base font-semibold group-hover:text-primary transition-colors">Kelola Gedung</h2>
            <p class="text-sm text-muted-foreground mt-1">
              Tambah, edit, dan hapus data gedung. Lihat statistik ruangan per gedung, cari data, dan ekspor laporan.
            </p>
          </header>
          <footer class="flex flex-wrap gap-1.5 mt-3">
            <span class="badge badge-secondary text-xs">CRUD</span>
            <span class="badge badge-secondary text-xs">Statistik</span>
            <span class="badge badge-secondary text-xs">Export PDF</span>
            <span class="badge badge-secondary text-xs">Export DOCX</span>
            <span class="badge badge-secondary text-xs">REST API</span>
          </footer>
        </a>

        <%# Card: Aset Ruangan %>
        <a href="/aset" id="card-aset-ruangan" class="card group hover:border-primary transition-all duration-200 cursor-pointer no-underline block">
          <header>
            <div class="flex items-start justify-between mb-3">
              <div class="bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-xl p-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 7V5a2 2 0 0 1 2-2h2"/>
                  <path d="M17 3h2a2 2 0 0 1 2 2v2"/>
                  <path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
                  <path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
                  <rect x="7" y="7" width="10" height="10" rx="1"/>
                </svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200 mt-1">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
            <h2 class="text-base font-semibold group-hover:text-primary transition-colors">Aset Ruangan</h2>
            <p class="text-sm text-muted-foreground mt-1">
              Kelola data ruangan beserta informasi asetnya. Filter per gedung, lacak kondisi dan status, ekspor laporan.
            </p>
          </header>
          <footer class="flex flex-wrap gap-1.5 mt-3">
            <span class="badge badge-secondary text-xs">CRUD</span>
            <span class="badge badge-secondary text-xs">Filter Gedung</span>
            <span class="badge badge-secondary text-xs">Export PDF</span>
            <span class="badge badge-secondary text-xs">Export DOCX</span>
            <span class="badge badge-secondary text-xs">REST API</span>
          </footer>
        </a>

      </div>
    </section>

    <%# API QUICK REFERENCE %>
    <section>
      <h2 class="text-sm font-medium text-muted-foreground uppercase tracking-widest mb-4">REST API — Endpoint</h2>
      <div class="card">
        <div class="card-content p-0">
          <table class="table w-full text-sm">
            <thead>
              <tr>
                <th class="w-24">Method</th>
                <th>Endpoint</th>
                <th class="hidden sm:table-cell">Fungsi</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="badge bg-green-500/15 text-green-700 dark:text-green-400 font-mono text-xs">GET</span></td>
                <td class="font-mono text-xs">/api/gedung</td>
                <td class="hidden sm:table-cell text-muted-foreground">Daftar semua gedung</td>
              </tr>
              <tr>
                <td><span class="badge bg-blue-500/15 text-blue-700 dark:text-blue-400 font-mono text-xs">POST</span></td>
                <td class="font-mono text-xs">/api/gedung</td>
                <td class="hidden sm:table-cell text-muted-foreground">Tambah gedung baru</td>
              </tr>
              <tr>
                <td><span class="badge bg-yellow-500/15 text-yellow-700 dark:text-yellow-400 font-mono text-xs">PUT</span></td>
                <td class="font-mono text-xs">/api/gedung/:id</td>
                <td class="hidden sm:table-cell text-muted-foreground">Update gedung</td>
              </tr>
              <tr>
                <td><span class="badge bg-red-500/15 text-red-700 dark:text-red-400 font-mono text-xs">DELETE</span></td>
                <td class="font-mono text-xs">/api/gedung/:id</td>
                <td class="hidden sm:table-cell text-muted-foreground">Hapus gedung</td>
              </tr>
              <tr>
                <td><span class="badge bg-green-500/15 text-green-700 dark:text-green-400 font-mono text-xs">GET</span></td>
                <td class="font-mono text-xs">/api/aset</td>
                <td class="hidden sm:table-cell text-muted-foreground">Daftar semua aset ruangan</td>
              </tr>
              <tr>
                <td><span class="badge bg-blue-500/15 text-blue-700 dark:text-blue-400 font-mono text-xs">POST</span></td>
                <td class="font-mono text-xs">/api/aset</td>
                <td class="hidden sm:table-cell text-muted-foreground">Tambah aset ruangan baru</td>
              </tr>
              <tr>
                <td><span class="badge bg-yellow-500/15 text-yellow-700 dark:text-yellow-400 font-mono text-xs">PUT</span></td>
                <td class="font-mono text-xs">/api/aset/:id</td>
                <td class="hidden sm:table-cell text-muted-foreground">Update aset ruangan</td>
              </tr>
              <tr>
                <td><span class="badge bg-red-500/15 text-red-700 dark:text-red-400 font-mono text-xs">DELETE</span></td>
                <td class="font-mono text-xs">/api/aset/:id</td>
                <td class="hidden sm:table-cell text-muted-foreground">Hapus aset ruangan</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

  </div><%# end max-w-5xl %>
</main>

</body>
</html>
